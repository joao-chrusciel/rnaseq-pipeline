process {
    cpus = 1
    memory = '2.GB'
    time = '2.h'

    withLabel: 'process_single' {
        cpus = 1
        memory = '2.GB'
        time = '1.h'
    }
    withLabel: 'process_medium' {
        cpus = 2
        memory = '4.GB'
        time = '4.h'
    }
    withLabel: 'process_high' {
        cpus = 4
        memory = '8.GB'
        time = '8.h'
    }
}