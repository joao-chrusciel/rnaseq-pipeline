process {
    cpus   = 1
    memory = '4.GB'
    time   = '2.h'

    withLabel: 'process_single' {
        cpus   = 1
        memory = '4.GB'
        time   = '1.h'
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = '16.GB'
        time   = '4.h'
    }
    withLabel: 'process_high' {
        cpus   = 8
        memory = '32.GB'
        time   = '8.h'
    }
}